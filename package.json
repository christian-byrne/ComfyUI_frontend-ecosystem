{
  "name": "comfyui-frontend-ecosystem",
  "version": "0.1.0",
  "private": true,
  "description": "Visualize and explore the ComfyUI extension API ecosystem",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "oxlint src && eslint src",
    "lint:fix": "oxlint src --fix && eslint src --fix",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,json,md}\""
  },
  "dependencies": {
    "@vueuse/core": "^14.2.0",
    "js-yaml": "^4.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.1.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.59.0",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "oxlint": "^1.59.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@10.33.0"
}
