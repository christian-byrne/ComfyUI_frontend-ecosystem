{
  "name": "comfyui-frontend-ecosystem",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "verify:quick": "pnpm typecheck",
    "rebuild": "bash scripts/rebuild.sh",
    "rebuild:offline": "bash scripts/rebuild.sh --skip-stars",
    "data:rollup": "bash scripts/rebuild.sh rollup",
    "data:stars": "bash scripts/rebuild.sh stars",
    "data:verify": "bash scripts/rebuild.sh data",
    "prepare": "husky"
  },
  "dependencies": {
    "@unhead/vue": "^3.1.0",
    "@vueuse/core": "^11.2.0",
    "@vueuse/router": "^11.2.0",
    "marked": "^18.0.3",
    "pinia": "^2.2.0",
    "shiki": "^4.0.2",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "happy-dom": "^15.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^2.0.0",
    "vue-axe": "^2.4.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
