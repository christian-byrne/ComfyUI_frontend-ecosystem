{
  "name": "comfyui-frontend-ecosystem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "rebuild": "bash scripts/rebuild.sh",
    "rebuild:offline": "bash scripts/rebuild.sh --skip-stars",
    "data:rollup": "bash scripts/rebuild.sh rollup",
    "data:stars": "bash scripts/rebuild.sh stars",
    "data:verify": "bash scripts/rebuild.sh data"
  },
  "dependencies": {
    "@vueuse/core": "^11.2.0",
    "@vueuse/router": "^11.2.0",
    "diff": "^5.2.0",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/diff": "^5.2.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.1.0"
  }
}
