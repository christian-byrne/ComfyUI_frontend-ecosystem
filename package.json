{
  "name": "comfyui-frontend-ecosystem",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:watch": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "vue-tsc --noEmit",
    "lint": "echo 'No linter configured'",
    "format": "echo 'No formatter configured'",
    "verify:quick": "pnpm typecheck",
    "rebuild": "bash scripts/rebuild.sh",
    "rebuild:offline": "bash scripts/rebuild.sh --skip-stars",
    "data:rollup": "bash scripts/rebuild.sh rollup",
    "data:stars": "bash scripts/rebuild.sh stars",
    "data:verify": "bash scripts/rebuild.sh data",
    "prepare": "husky"
  },
  "dependencies": {
    "@unhead/vue": "^3.1.0",
    "@vueuse/core": "^11.2.0",
    "@vueuse/router": "^11.2.0",
    "diff": "^5.2.0",
    "marked": "^18.0.3",
    "pinia": "^2.2.0",
    "shiki": "^4.0.2",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/diff": "^5.2.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
